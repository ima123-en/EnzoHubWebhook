                HttpService:PostAsync(WEBHOOK_URL, json, Enum.HttpContentType.ApplicationJson)
            end
        end)
    end)
end

local lastKey, lastTime = nil, 0
local stealPatterns = { "you stole ", "you have stolen " }

local function tryExtract(plain)
    local l = plain:lower()
    for _, pat in ipairs(stealPatterns) do
        local idx = l:find(pat, 1, true)
        if idx then
            local raw = plain:sub(idx + #pat)
            raw = raw:gsub(" from you.*", ""):gsub("[!%.].*", "")
            raw = strip(raw)
            if raw ~= "" then return raw end
        end
    end
    return nil
end

local function onText(txt)
    if type(txt) ~= "string" or txt == "" then return end
    local plain = strip(txt)
    local item  = tryExtract(plain)
    if not item then return end

    local key = item:lower()
    local now = tick()
    if key == lastKey and now - lastTime < 3 then return end
    lastKey  = key
    lastTime = now

    task.spawn(function()
        scanAll()
        task.wait(0.1)
        sendWebhook(item)
    end)
end

local function hookObj(obj)
    if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
        onText(obj.Text)
        obj:GetPropertyChangedSignal("Text"):Connect(function()
            onText(obj.Text)
        end)
    end
end

local function hookGui(g)
    for _, d in ipairs(g:GetDescendants()) do hookObj(d) end
    g.DescendantAdded:Connect(hookObj)
end

