local function formatNumber(num)
    if not num or num == 0 then return "Unknown" end
    if num >= 1e12 then return string.format("%.2fT", num/1e12)
    elseif num >= 1e9 then return string.format("%.2fB", num/1e9)
    elseif num >= 1e6 then return string.format("%.2fM", num/1e6)
    elseif num >= 1e3 then return string.format("%.2fK", num/1e3)
    else return tostring(math.floor(num)) end
end

local function strip(str)
    if type(str) ~= "string" then return "" end
    return (str:gsub("<.->", ""):gsub("^%s+", ""):gsub("%s+$", ""))
end

local brainrotCache = {}

local function scanPlot(plot)
    pcall(function()
        local ch = Synchronizer:Get(plot.Name)
        if not ch then return end
        local owner = ch:Get("Owner")
        local ownerName = (typeof(owner) == "Instance" and owner.Name) or (type(owner) == "table" and owner.Name) or tostring(owner)
        if not ownerName or ownerName == LP.Name then return end

        local al = ch:Get("AnimalList")
        if not al then return end
        for _, ad in pairs(al) do
            if type(ad) == "table" then
                local aInfo = AnimalsData[ad.Index]
                if aInfo then
                    local displayName = aInfo.DisplayName or ad.Index
                    local gv = AnimalsShared:GetGeneration(ad.Index, ad.Mutation, ad.Traits, nil)
                    brainrotCache[displayName:lower()] = {
                        name     = displayName,
                        mutation = ad.Mutation or "None",
                        genText  = formatNumber(gv),
                        genValue = gv,
                        owner    = ownerName,
                    }
                end
            end
        end
    end)
end

local function scanAll()
    local plots = Workspace:FindFirstChild("Plots")
    if plots then for _, p in ipairs(plots:GetChildren()) do scanPlot(p) end end
end

local function sendWebhook(stolenName)
    local cleanName = strip(stolenName or ""):gsub("!", "")
    local baseKey = cleanName:gsub("%s*%([^)]*%)", ""):lower():gsub("^%s+", ""):gsub("%s+$", "")
    
    local data = brainrotCache[baseKey] or {}
    local isSpecial = ALWAYS_SEND[baseKey]
    local genValue = data.genValue or 0
    
    if not isSpecial and genValue < MIN_GEN_VALUE then return end

    local mutation = data.mutation or "None"
    local genText  = data.genText or "Unknown"
    local owner    = data.owner or "Unknown"
    local headshot = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. LP.UserId .. "&width=150&height=150&format=png"

    local embed = {
        title = "New Steal Logged",
        description = string.format(
            "```txt\nAnimal:   %s\nMutation: %s\nGen:      %s\nOwner:    %s\n```",
            cleanName,
            mutation,
            genText,
            owner
        ),
        color = 0x000000,
        author = {
            name = "SMKT HUB | " .. LP.Name,
            icon_url = headshot
        },
        fields = {
            { name = "Stealer", value = "`" .. LP.Name .. "`", inline = true },
            { name = "Original Owner", value = "`" .. owner .. "`", inline = true },
            { name = "Generation", value = "`" .. genText .. "`", inline = true }
        },
        footer = { text = "SMKT HUB • " .. LP.Name },
        timestamp = DateTime.now():ToIsoDate()
    }

    local payload = HttpService:JSONEncode({
        username = "SMKT HUB",
        avatar_url = headshot,
        embeds = { embed }
    })

    task.spawn(function()
        local req = (syn and syn.request) or (http and http.request) or (fluxus and fluxus.request) or request or http_request
        if req then
            pcall(function() req({ Url = WEBHOOK_URL, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = payload }) end)
        else
            pcall(function() HttpService:PostAsync(WEBHOOK_URL, payload, Enum.HttpContentType.ApplicationJson) end)
        end
    end)
end

local lastKey, lastTime = nil, 0
local stealPatterns = { "you stole ", "you have stolen " }

local function onText(txt)
    local plain = strip(txt)
    local lower = plain:lower()
    local item = nil

    for _, pat in ipairs(stealPatterns) do
        local idx = lower:find(pat, 1, true)
        if idx then
            item = plain:sub(idx + #pat):gsub(" from you.*", ""):gsub("[!%.].*", "")
            item = strip(item)
            break
        end
    end

    if item then
        local key = item:lower()
        local now = tick()
        -- ANTI DOUBLE SEND (5 Sekunden Cooldown für das gleiche Item)
        if key == lastKey and (now - lastTime) < 5 then return end
        
        lastKey = key
        lastTime = now

        task.spawn(function()
            scanAll()
            task.wait(0.2)
            sendWebhook(item)
        end)
    end
end

local function hookObj(obj)
    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
        if obj.Text ~= "" then onText(obj.Text) end
        obj:GetPropertyChangedSignal("Text"):Connect(function() onText(obj.Text) end)
    end
end

