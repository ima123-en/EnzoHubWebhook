local function formatNumber(num)
    if not num or num == 0 then return "Unknown" end
    if num >= 1e12 then return string.format("%.2fT", num/1e12)
    elseif num >= 1e9 then return string.format("%.2fB", num/1e9)
    elseif num >= 1e6 then return string.format("%.2fM", num/1e6)
    elseif num >= 1e3 then return string.format("%.2fK", num/1e3)
    else return tostring(math.floor(num)) end
end

local function strip(str)
    if type(str) ~= "string" then return "" end
    return (str:gsub("<.->", ""):gsub("^%s+", ""):gsub("%s+$", ""))
end

local brainrotCache = {}
local pendingSteal = nil

local function getOwnerName(owner)
    if not owner then return nil end
    if typeof(owner) == "Instance" and owner:IsA("Player") then return owner.Name end
    if type(owner) == "table" then return owner.Name end
    if type(owner) == "string" then return owner end
    return nil
end

local function scanPlot(plot)
    pcall(function()
        local ch = Synchronizer:Get(plot.Name)
        if not ch then return end
        local owner = ch:Get("Owner")
        local ownerName = getOwnerName(owner)
        if not ownerName then return end
        local isOwn = false
        if typeof(owner) == "Instance" and owner:IsA("Player") then
            isOwn = owner.UserId == LP.UserId
        elseif type(owner) == "table" and owner.UserId then
            isOwn = owner.UserId == LP.UserId
        end
        if isOwn then return end
        local al = ch:Get("AnimalList")
        if not al then return end
        for _, ad in pairs(al) do
            if type(ad) == "table" then
                local aInfo = AnimalsData[ad.Index]
                if aInfo then
                    local displayName = aInfo.DisplayName or ad.Index
                    local key = displayName:lower()
                    local mut = ad.Mutation or "None"
                    local gv = AnimalsShared:GetGeneration(ad.Index, ad.Mutation, ad.Traits, nil)
                    local existing = brainrotCache[key]
                    if not existing or gv > (existing.genValue or 0) then
                        brainrotCache[key] = {
                            name     = displayName,
                            mutation = mut,
                            genText  = formatNumber(gv),
                            genValue = gv,
                            owner    = ownerName,
                        }
                    end
                end
            end
        end
    end)
end

local function scanAll()
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return end
    for _, p in ipairs(plots:GetChildren()) do
        scanPlot(p)
    end
end

